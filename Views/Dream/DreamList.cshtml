@using Microsoft.CodeAnalysis.CSharp.Syntax
@model IEnumerable<Lucy.Models.Dream>

@{
    ViewData["Title"] = "DreamList";
}

<h1>DreamList</h1>

<p>
    <a asp-controller="Dream" asp-action="AddDream" class="btn btn-primary">Create New</a>
</p>
@if (Model.Count() > 0)
{
    <table class="table">
        <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Story)
            </th>
            <th></th>
        </tr>
        </thead>
        <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Title)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Story)
                </td>
                <td>
                    <a asp-action="EditDream" asp-route-id="@item.Id">Edit</a> | <a asp-action="DeleteDream" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>You don't have any dreams yet, so go ahead and add one!</p>
}